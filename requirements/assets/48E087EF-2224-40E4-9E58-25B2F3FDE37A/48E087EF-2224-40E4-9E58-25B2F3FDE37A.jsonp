1317133,"x":4.0501829385757446,"width":34.170000000000002,"height":21}},{"text":"方案一：酒店配置","targetRectangle":{"y":110.79535198211664,"x":4.0501829385757446,"width":120,"height":21}},{"text":"亮点：淋浴房与厕所在次卫的两侧, 理论上互不影响","targetRectangle":{"y":131.79535198211664,"x":31.60424792766571,"width":338.33999999999997,"height":21}},{"text":"隐忧：次卫镜子对床","targetRectangle":{"y":153.21535015106195,"x":31.60424792766571,"width":135,"height":21}},{"text":"方案二：原始配置","targetRectangle":{"y":174.21535015106195,"x":4.0501829385757446,"width":120,"height":21}},{"text":"亮点：床不会对着镜子, 次卫可以有多个独立分区","targetRectangle":{"y":195.21535015106195,"x":28.564817190170288,"width":323.95500000000004,"height":21}},{"text":"隐忧：次卫空间一部分用做柜子. (净衣或储藏室) 整体次卫可用空间较小. 另外洗脸盆太小了. 整体尺寸需要调整","targetRectangle":{"y":216.21535015106195,"x":26.094491243362427,"width":413.94000000000005,"height":42}},{"text":"方案三：","targetRectangle":{"y":258.21535015106195,"x":4.0501829385757446,"width":60,"height":21}},{"text":"亮点：次卫入口与次卧入口不互相遮挡","targetRectangle":{"y":279.21535015106195,"x":31.60424792766571,"width":255,"height":21}},{"text":"隐忧：整体动线是最长的, 排水有疑问","targetRectangle":{"y":300.21535015106195,"x":31.65018367767334,"width":248.95500000000004,"height":21}},{"text":"方案四:","targetRectangle":{"y":321.21535015106195,"x":4.0501829385757446,"width":49.170000000000002,"height":21}},{"text":"亮点: 套房最开放布置","targetRectangle":{"y":342.63534832000727,"x":28.564817190170288,"width":143.34,"height":21}},{"text":"隐忧: 次卧与次卫没有分隔, 床头直视镜子","targetRectangle":{"y":364.05534648895258,"x":28.564817190170288,"width":272.29500000000002,"height":21}},{"text":"6355130019309900004349821.jpg","targetRectangle":{"y":570.0333251953125,"x":1124.5782470703125,"width":788.478759765625,"height":503.70623779296875}},{"text":"从次卧到次卫可以参考红珠山的拉门. (右边电视后面是拉门)","targetRectangle":{"y":499.69555532932281,"x":1132.411372314453,"width":287.62799999999993,"height":60}},{"text":"另一种卧室与浴室的开放方式: 两片对开的推拉门 (方案四, 床头转向飘窗方向)","targetRectangle":{"y":1018.7861168384552,"x":23.82998960876
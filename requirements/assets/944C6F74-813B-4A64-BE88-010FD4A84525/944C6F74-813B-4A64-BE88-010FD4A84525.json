":754.49500000000012,"height":148.27999222278595}},{"text":"需要边几或罗汉床小台子来放茶杯与遥控器","targetRectangle":{"y":873.33148622512817,"x":125.45444214344025,"width":665,"height":59.099998831748962}},{"text":"座位附近应该有插座充手机或平板","targetRectangle":{"y":932.43148505687714,"x":125.45444214344025,"width":525,"height":49}},{"text":"7c: 一般优先度  (有疑问) ","targetRectangle":{"y":217.27153015136719,"x":1036.1123191177439,"width":397.77500000000009,"height":60.079994559288025}},{"text":"地毯","targetRectangle":{"y":277.35152471065521,"x":1091.3956520020556,"width":70,"height":59.099998831748962}},{"text":"如有地毯考虑将地毯收在电视墙面的地柜","targetRectangle":{"y":336.45152354240417,"x":1132.4972800075602,"width":630,"height":59.099998831748962}},{"text":"7d: 低优先度 (倾向不安装) ","targetRectangle":{"y":395.55152237415314,"x":1043.3956520020556,"width":422.48500000000013,"height":60.079994559288025}},{"text":"无","targetRectangle":{"y":455.63151693344116,"x":1091.3956520020556,"width":35,"height":59.099998831748962}},{"text":"7e: 黑名单","targetRectangle":{"y":514.73151576519012,"x":1036.1123191177439,"width":162.71499999999992,"height":60.079994559288025}},{"text":"大型展示柜, 没有陈列\/展示需求. 能接受少量造型, 但不要大型柜体","targetRectangle":{"y":574.81151032447815,"x":1091.3956520020556,"width":774.33999999999992,"height":104.17999339103699}},{"text":"中央大茶几, 会坐在主沙发或地上(背靠沙发, 所以不要中央茶几)","targetRectangle":{"y":678.99150371551514,"x":1091.3956520020556,"width":784.42000000000007,"height":105.15998911857605}},{"text":"客厅 - 7","targetRectangle":{"y":1.5970859527587891,"x":2.6174357235431671,"width":192.42132012579563,"height":79}},{"text":"主要起居空间为日间活动核心，每日逾八成时间在此使用。为配合多元观看姿势（沙发坐姿或地面盘坐），电视采最大化配置，并取消中央茶几，以保留弹性动线。此区亦兼作午间小憩之用。另预留遥控器收纳处及垃圾桶摆放位置；由于此处仅产生干式垃圾（如包装纸、废纸等），垃圾桶可选用简约款式。电视采超薄壁挂安装，力求墙面维持素净简洁，避免过多装饰。另外避免高度对称设计","targetRectangle":{"y":73.908343315124512,"x":5.4480838775634766,"width":1890,"height":126}}],"baseLayer":{"animations":[],"initialState":{"affineTransform":[1,0,0,1,0,0],"masksToBounds":false,"rotation":0,"scale":1,"position":{"pointX":960,"